# Server-only model provider configuration. Never use VITE_* for credentials.
# Select "openai" for the official Responses API or "openrouter" for the project-owner
# selected OpenRouter compatibility adapter. If omitted, OpenAI is used when an
# OPENAI_API_KEY is present; otherwise OpenRouter is selected.
AMBIGUITY_COMPILER_MODEL_PROVIDER=openrouter

# Official OpenAI Responses API (structured JSON Schema output).
# OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5.6

# OpenRouter compatibility adapter (also requires strict JSON Schema support).
# OPENROUTER_API_KEY=replace-me
OPENROUTER_MODEL=openai/gpt-5.6-sol
OPENROUTER_SITE_URL=http://localhost:3001

# Both the web server and MCP server must use this same absolute path when they
# run from different working directories. Leave unset for the shared local default:
# mcp-server/.data/compilations.json
# AMBIGUITY_COMPILER_DATA_FILE=D:\\data\\ambiguity-compiler\\compilations.json
AMBIGUITY_COMPILER_WORKSPACE_ID=default

# Optional Streamable HTTP MCP server settings. Omit MCP_TRANSPORT to use stdio.
# MCP_TRANSPORT=http
# MCP_PORT=3333
